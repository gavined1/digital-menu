# Copy to .env.local and fill in values. Do not commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or use the newer name (either anon or publishable is enough):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Guest QR access cookie signing (min 16 chars). Example: openssl rand -base64 24
MENU_ACCESS_SECRET=

# Production: https://your-domain.com (no trailing slash)
# NEXT_PUBLIC_APP_URL=

# Optional: Sentry
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
